{
  "name": "hayya-baca",
  "version": "2.0.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:e2e": "./scripts/e2e-backend.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@tanstack/.*|fuzzball)"
    ],
    "setupFilesAfterEnv": [
      "./src/__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "setup\\.ts$",
      "e2e-sync-backend\\.test\\.ts$",
      "integration-sync\\.test\\.ts$",
      "usecase-recalculate-race\\.test\\.ts$",
      "usecase-recalculate-partial-pull\\.test\\.ts$",
      "usecase-progress-merge-counter\\.test\\.ts$",
      "usecase-sync-partial-mark-recovery\\.test\\.ts$",
      "usecase-sync-indicator\\.test\\.tsx$",
      "usecase-sync-mount-trigger\\.test\\.ts$",
      "usecase-sync-netinfo-reconnect\\.test\\.ts$",
      "usecase-game-spend-persistence\\.test\\.ts$",
      "usecase-sync-reading-progress-partial\\.test\\.ts$",
      "usecase-sync-telemetry\\.test\\.ts$",
      "usecase-full-reward-lifecycle\\.test\\.ts$",
      "usecase-opportunistic-push\\.test\\.ts$",
      "usecase-sync-session-switch-flushes-all\\.test\\.ts$",
      "usecase-sync-mount-race\\.test\\.ts$",
      "usecase-sync-network-drop-retry\\.test\\.ts$",
      "e2e/starter\\.test\\.js$"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ]
  },
  "dependencies": {
    "@mhpdev/react-native-speech": "^1.4.0",
    "@react-native-community/netinfo": "11.5.2",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~55.0.5",
    "expo-av": "^16.0.8",
    "expo-constants": "^55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-device": "~55.0.9",
    "expo-file-system": "^55.0.10",
    "expo-font": "^55.0.4",
    "expo-intent-launcher": "^55.0.8",
    "expo-linking": "^55.0.7",
    "expo-router": "^55.0.4",
    "expo-speech-recognition": "^3.1.1",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "fuzzball": "^2.2.3",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "^0.7.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "better-sqlite3": "^12.8.0",
    "detox": "^20.51.4",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
