<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <!--            <solid android:color="#D9C19EFF" />-->
            <gradient
                android:angle="75"
                android:centerColor="#BAF6F2CE"
                android:centerX="0.3"
                android:centerY="0.5"
                android:endColor="#B7FF7AA7"
                android:startColor="#D9C19EFF"
                android:type="linear" />
            <padding
                android:bottom="0dp"
                android:left="10dp"
                android:right="10dp"
                android:top="15dp" />

        </shape>
    </item>

    <item
        android:bottom="-25dp"
        android:left="-25dp"
        android:right="-25dp"
        android:top="-18dp">
        <shape>
            <corners android:radius="5dp" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="15dp"
                android:color="#673AB7" />
        </shape>
    </item>

</layer-list>