<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >

    <data>

        <variable
            name="vm"
            type="com.ihfazh.ksatriamuslim.vm.HomeViewModel" />

        <variable
            name="children"
            type="com.ihfazh.ksatriamuslim.domain.Children" />

        <variable
            name="childViewModel"
            type="com.ihfazh.ksatriamuslim.vm.ChildViewModel" />

        <import type="android.view.View" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ic_artboard8"
        tools:context=".fragments.HomeFragment">

        <ImageView
            android:id="@+id/avatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="16dp"
            android:clickable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="MissingConstraints"
            tools:src="@drawable/ic_baseline_mic_24" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/book_rv"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:itemCount="2"
            tools:layoutManager="GridLayoutManager"
            tools:listitem="@layout/book_item"
            android:layout_marginStart="16dp"
            android:layout_marginTop="80dp"
            android:layout_marginEnd="140dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/book_list_background"
            android:paddingStart="10dp"
            android:paddingTop="15dp"
            android:paddingEnd="10dp"
            tools:spanCount="3" />

        <include
            android:id="@+id/starLayout"
            layout="@layout/star_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="@id/coinLayout"
            app:layout_constraintEnd_toStartOf="@id/coinLayout"
            app:layout_constraintTop_toTopOf="@id/coinLayout" />

        <include
            android:id="@+id/coinLayout"
            layout="@layout/coin_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/updateDataBtn"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/circle_button_background"
            android:clickable="@{!vm.updateClicked}"
            android:enabled="@{!vm.updateClicked}"
            android:onClick="@{() -> vm.updateAllData()}"
            android:src="@drawable/ic_baseline_update_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/parentButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/circle_button_background"
            android:src="@drawable/ic_baseline_lock_24"
            app:layout_constraintStart_toStartOf="@id/updateDataBtn"
            app:layout_constraintEnd_toEndOf="@id/updateDataBtn"
            app:layout_constraintBottom_toTopOf="@id/updateDataBtn"
            android:layout_marginBottom="8dp" />

        <ImageButton
            android:id="@+id/gameBtn"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/circle_button_background"
            android:src="@drawable/ic_baseline_videogame_asset_24"
            app:layout_constraintBottom_toTopOf="@id/parentButton"
            app:layout_constraintEnd_toEndOf="@id/updateDataBtn"
            app:layout_constraintStart_toStartOf="@id/updateDataBtn" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>