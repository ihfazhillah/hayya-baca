{
  "id": 4,
  "title": "Jarir Bin Abdillah Menghancurkan Ka'bah Yaman",
  "cover": "cover_books/cover_jarir_bin_abdillah.png",
  "reference_text_ar": "",
  "reference_text_id": "",
  "pages": [
    {
      "page": 1,
      "text": "Jarir bin Abdillah Menghancurkan Ka'bah Yaman",
      "audio": null
    },
    {
      "page": 2,
      "text": "Ditahun meninggalnya Rosululloh shollallohu 'alaihi wasallam,",
      "audio": null
    },
    {
      "page": 3,
      "text": "beliau berkata kepada Jarir bin Abdillah Al Bajali",
      "audio": null
    },
    {
      "page": 4,
      "text": "\"Maukah kamu mengistirahatkanku dari Dzul Khulafah,",
      "audio": null
    },
    {
      "page": 5,
      "text": "yang dikenal sebagai ka'bah Yaman?\"",
      "audio": null
    },
    {
      "page": 6,
      "text": "Jarir pun menyanggupi.",
      "audio": null
    },
    {
      "page": 7,
      "text": "Namun, dia berkata",
      "audio": null
    },
    {
      "page": 8,
      "text": "\"Wahai Rosululloh, aku tidak bisa kokoh duduk diatas kuda.\"",
      "audio": null
    },
    {
      "page": 9,
      "text": "Rosululloh shollallohu 'alaihi wasallam pun menepuk dada Jarir",
      "audio": null
    },
    {
      "page": 10,
      "text": "dan berdoa: \"Ya Alloh, kokohkan dia.",
      "audio": null
    },
    {
      "page": 11,
      "text": "Jadikan dia seorang",
      "audio": null
    },
    {
      "page": 12,
      "text": "yang menjadi sebab orang lain mendapatkan petunjuk",
      "audio": null
    },
    {
      "page": 13,
      "text": "lagi mendapatkan petunjuk.\"",
      "audio": null
    },
    {
      "page": 14,
      "text": "Keluarlah Jarir menuju Dzul Khulafah, Ka'bah Yaman.",
      "audio": null
    },
    {
      "page": 15,
      "text": "Beliau membawa 50 pasukan dari kaumnya.",
      "audio": null
    },
    {
      "page": 16,
      "text": "Disana, mereka menghancurkan Dzul Khulafah",
      "audio": null
    },
    {
      "page": 17,
      "text": "dan juga berhasil membakarnya sampai hangus.",
      "audio": null
    }
  ]
}