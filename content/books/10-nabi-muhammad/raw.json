{
  "id": 10,
  "title": "Nabi Muhammad",
  "cover": "cover_books/cover_Nabi_Muhammad.png",
  "reference_text_ar": "",
  "reference_text_id": "",
  "pages": [
    {
      "page": 1,
      "text": "Nabi Muhammad shollallohu 'alaihi wasallam",
      "audio": "audiobook/10/1"
    },
    {
      "page": 2,
      "text": "Beliau adalah nabi terakhir yang Alloh utus kepada manusia.",
      "audio": "audiobook/10/2"
    },
    {
      "page": 3,
      "text": "Mengajak manusia untuk",
      "audio": null
    },
    {
      "page": 4,
      "text": "hanya beribadah kepada Alloh,",
      "audio": "audiobook/10/3"
    },
    {
      "page": 5,
      "text": "hanya meminta dan takut kepada Alloh.",
      "audio": "audiobook/10/4"
    },
    {
      "page": 6,
      "text": "Ayahnya bernama Abdulloh dan ibunya bernama Aminah.",
      "audio": "audiobook/10/5"
    },
    {
      "page": 7,
      "text": "Ayahnya meninggal saat ibunya sedang mengandungnya.",
      "audio": "audiobook/10/6"
    },
    {
      "page": 8,
      "text": "Nabi Muhammad shollallohu 'alaihi wasallam lahir di tahun gajah.",
      "audio": null
    },
    {
      "page": 9,
      "text": "Yaitu pada saat Raja Abrahah menyerang ka'bah",
      "audio": "audiobook/10/7"
    },
    {
      "page": 10,
      "text": "dengan membawa tentara gajah.",
      "audio": "audiobook/10/8"
    },
    {
      "page": 11,
      "text": "Ibunya meninggal",
      "audio": "audiobook/10/9"
    },
    {
      "page": 12,
      "text": "ketika Beliau shollallohu 'alaihi wasallam berumur 6 tahun.",
      "audio": null
    },
    {
      "page": 13,
      "text": "Kakeknya yang bernama Abdul Muththolib",
      "audio": "audiobook/10/10"
    },
    {
      "page": 14,
      "text": "mengasuhnya selama 2 tahun, dan kemudian meninggal.",
      "audio": null
    },
    {
      "page": 15,
      "text": "Ketika Beliau shollallohu 'alaihi wasallam berumur 8 tahun,",
      "audio": null
    },
    {
      "page": 16,
      "text": "kakeknya meninggal.",
      "audio": null
    },
    {
      "page": 17,
      "text": "Lalu, pamannya yang bernama Abu Tholib merawatnya sampai besar.",
      "audio": null
    }
  ]
}