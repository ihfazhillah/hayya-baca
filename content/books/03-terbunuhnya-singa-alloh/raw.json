  "pages": [
    {
      "page": 1,
      "text": "Terbunuhnya Singa Alloh",
      "audio": null
    },
    {
      "page": 2,
      "text": "Sebelum terjadinya perang uhud,",
      "audio": null
    },
    {
      "page": 3,
      "text": "Jubair bin Muth'im berkata kepada Wahsyi bin Harb",
      "audio": null
    },
    {
      "page": 4,
      "text": "\"Kalau kamu bunuh Hamzah, kamu akan aku bebaskan\"",
      "audio": null
    },
    {
      "page": 5,
      "text": "Hamzah membunuh Thu'aim bin Adi di perang badar",
      "audio": null
    },
    {
      "page": 6,
      "text": "Thu'aim adalah pamannya Jubair",
      "audio": null
    },
    {
      "page": 7,
      "text": "Jubair ingin Wasyi mebalaskan dendam kepada Hamzah",
      "audio": null
    },
    {
      "page": 8,
      "text": "karena telah membunuh pamannya.",
      "audio": null
    },
    {
      "page": 9,
      "text": "Perang uhud pun berkecamuk.",
      "audio": null
    },
    {
      "page": 10,
      "text": "Wahsyi bin Harb menunggu dan bersembunyi dibalik batu besar.",
      "audio": null
    },
    {
      "page": 11,
      "text": "Hamzah, sang singa Alloh seperti biasa",
      "audio": null
    },
    {
      "page": 12,
      "text": "maju dengan gagah berani melawan orang kafir.",
      "audio": null
    },
    {
      "page": 13,
      "text": "Tombaknya pun mengenai bawah pusar. Menembus belakang.",
      "audio": null
    },
    {
      "page": 14,
      "text": "Syahidlah Hamzah, sang singa Alloh dan RosulNya shollallohu 'alaihi wasallam.",
      "audio": null
    },
    {
      "page": 15,
      "text": "Kabar syahidnya Hamzah pun tersebar.",
      "audio": null
    },
    {
      "page": 16,
      "text": "Rosululloh shollallohu 'alaihi wasallam pun juga mendengarnya.",
      "audio": null
    },
    {
      "page": 17,
      "text": "Rosululloh shollallohu 'alaihi wasallam sedih mendengarnya.",
      "audio": null
    },
    {
      "page": 18,
      "text": "Singa Alloh, orang yang sangat berani dan gagah,",
      "audio": null
    },
    {
      "page": 19,
      "text": "sekaligus paman Rosululloh shollallohu 'alaihi wasallam telah meninggal.",
      "audio": null
    }
  ]
}