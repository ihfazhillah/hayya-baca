{
  "id": 6,
  "title": "Kisah Buhairo, Sang Pendeta",
  "cover": "cover_books/cover_buhairo.png",
  "reference_text_ar": "",
  "reference_text_id": "",
  "pages": [
    {
      "page": 1,
      "text": "Kisah Buhairo",
      "audio": "audiobook/6/1"
    },
    {
      "page": 2,
      "text": "Suatu hari,",
      "audio": "audiobook/6/2"
    },
    {
      "page": 3,
      "text": "Nabi shollallohu 'alaihi wasallam bersama pamannya",
      "audio": "audiobook/6/3"
    },
    {
      "page": 4,
      "text": "pergi berdagang menuju Syam.",
      "audio": "audiobook/6/4"
    },
    {
      "page": 5,
      "text": "Ketika hendak sampai,",
      "audio": "audiobook/6/5"
    },
    {
      "page": 6,
      "text": "disana ada Ahli Ibadah yang bernama Buhairo.",
      "audio": "audiobook/6/6"
    },
    {
      "page": 7,
      "text": "Buhairo memperhatikan kafilah dagang,",
      "audio": "audiobook/6/7"
    },
    {
      "page": 8,
      "text": "kemudian memegang tangan Nabi Muhammad",
      "audio": "audiobook/6/8"
    },
    {
      "page": 9,
      "text": "shollallohu 'alaihi wasallam",
      "audio": null
    },
    {
      "page": 10,
      "text": "seraya berkata",
      "audio": "audiobook/6/9"
    },
    {
      "page": 11,
      "text": "\"Orang ini akan jadi pemimpin semua manusia,",
      "audio": "audiobook/6/10"
    },
    {
      "page": 12,
      "text": "orang ini adalah utusan Alloh,",
      "audio": "audiobook/6/11"
    },
    {
      "page": 13,
      "text": "dia diutus sebagai rahmat semesta alam\"",
      "audio": "audiobook/6/12"
    },
    {
      "page": 14,
      "text": "Orang orang bertanya: \"kok kamu bisa tahu?\"",
      "audio": "audiobook/6/13"
    },
    {
      "page": 15,
      "text": "Buhairo menjawab",
      "audio": "audiobook/6/14"
    },
    {
      "page": 16,
      "text": "\"Kalian Ketika melewati Al 'Aqobah",
      "audio": "audiobook/6/15"
    },
    {
      "page": 17,
      "text": "semua pepohonan dan bebatuan sujud kepadanya.",
      "audio": "audiobook/6/16"
    },
    {
      "page": 18,
      "text": "Pepohonan dan bebatuan tidaklah sujud kecuali kepada Nabi.",
      "audio": "audiobook/6/17"
    },
    {
      "page": 19,
      "text": "Aku juga tahu karena ada cap kenabian di punggungnya",
      "audio": "audiobook/6/18"
    },
    {
      "page": 20,
      "text": "yang bentuknya seperti buah apel.\"",
      "audio": "audiobook/6/19"
    },
    {
      "page": 21,
      "text": "Lalu Buhairo mempersiapkan hidangan",
      "audio": null
    },
    {
      "page": 22,
      "text": "untuk kafilah dagang dan kemudian mengantarkannya.",
      "audio": null
    },
    {
      "page": 23,
      "text": "Pada saat itu,",
      "audio": null
    },
    {
      "page": 24,
      "text": "Nabi Muhammad shollallohu 'alaihi wasallam sedang menjaga unta.",
      "audio": null
    },
    {
      "page": 25,
      "text": "Buhairo berkata: \"Panggil dia.\"",
      "audio": null
    },
    {
      "page": 26,
      "text": "Maka datanglah Nabi Muhammad shollallohu 'alaihi wasallam",
      "audio": null
    },
    {
      "page": 27,
      "text": "dalam keadaan dipayungi awan",
      "audio": null
    },
    {
      "page": 28,
      "text": "dan orang orang sudah mendahului beliau berteduh dibawah pohon.",
      "audio": null
    },
    {
      "page": 29,
      "text": "Nabi Muhammad shollallohu 'alaihi wasallam pun duduk,",
      "audio": null
    },
    {
      "page": 30,
      "text": "lalu pohonnya memayungi beliau.",
      "audio": null
    },
    {
      "page": 31,
      "text": "Buhairo pun berkata: \"Lihat, pohon itu memayunginya\"",
      "audio": null
    },
    {
      "page": 32,
      "text": "Ketika kafilah dagang akan meneruskan perjalanan,",
      "audio": null
    },
    {
      "page": 33,
      "text": "Buhairo berpesan",
      "audio": null
    },
    {
      "page": 34,
      "text": "untuk tidak melanjutkan perjalanan ke Romawi.",
      "audio": null
    },
    {
      "page": 35,
      "text": "Kenapa?",
      "audio": null
    },
    {
      "page": 36,
      "text": "Karena orang orang Romawi kalau tahu",
      "audio": null
    },
    {
      "page": 37,
      "text": "disitu ada Nabi Muhammad shollallohu 'alaihi wasallam,",
      "audio": null
    },
    {
      "page": 38,
      "text": "mereka akan membunuhnya.",
      "audio": null
    },
    {
      "page": 39,
      "text": "Akhirnya, pamannnya yang Bernama Abu Tholib",
      "audio": null
    },
    {
      "page": 40,
      "text": "mengembalikan Nabi Muhammad shollallohu 'alaihi wasallam,",
      "audio": null
    },
    {
      "page": 41,
      "text": "memerintahkannya pulang, bersama Abu Bakar dan Bilal.",
      "audio": null
    },
    {
      "page": 42,
      "text": "Begitulah Alloh menyelamatkan NabiNya",
      "audio": null
    },
    {
      "page": 43,
      "text": "dari orang orang yang memusuhinya,",
      "audio": null
    },
    {
      "page": 44,
      "text": "bahkan sebelum dia diutus sebagai nabi.",
      "audio": null
    }
  ]
}