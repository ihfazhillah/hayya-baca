<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout3"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <ImageView
            android:id="@+id/background_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@string/background_image"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/main_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            android:bufferType="spannable"
            android:fontFamily="@font/playtime"
            android:paddingStart="100dp"
            android:paddingEnd="100dp"
            android:shadowColor="@android:color/darker_gray"
            android:shadowRadius="5"
            android:textAlignment="center"
            android:textColorHighlight="@color/white"
            android:textSize="@dimen/main_text_size"
            app:layout_constraintTop_toBottomOf="@id/page_number_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Abu Dujanah. Siapakah abu dujanah itu? Apakah kamu penasaran?" />

        <ImageButton
            android:id="@+id/next_icon"
            android:layout_width="@dimen/nav_width"
            android:layout_height="@dimen/nav_height"
            android:layout_margin="@dimen/reading_margin"
            android:background="@drawable/ic_caret_right"
            android:contentDescription="@string/next_page"
            android:scaleType="centerInside"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/prev_icon"
            android:layout_width="@dimen/nav_width"
            android:layout_height="@dimen/nav_height"
            android:layout_margin="@dimen/reading_margin"
            android:background="@drawable/ic_caret_left"
            android:contentDescription="@string/prev_page"
            android:scaleType="centerInside"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/page_number_icon"
            android:layout_width="@dimen/page_icon_wh"
            android:layout_height="@dimen/page_icon_wh"
            android:layout_margin="@dimen/reading_margin"
            android:src="@drawable/ic_read_book"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/page_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playtime"
            android:textSize="@dimen/page_num_size"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/page_number_icon"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="100"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton
            android:id="@+id/btn_home"
            android:layout_width="@dimen/reading_icon_wh"
            android:layout_height="@dimen/reading_icon_wh"
            android:layout_margin="@dimen/reading_margin"
            android:background="@drawable/circle_button_background"
            android:contentDescription="@string/back_to_home"
            android:src="@drawable/ic_baseline_home_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/loading"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/book_loader" />


        <TextView
            android:id="@+id/starAddedTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="200sp"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="+4" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
